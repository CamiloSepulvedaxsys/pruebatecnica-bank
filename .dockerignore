# =============================================================================
# .dockerignore - Archivos excluidos del contexto de build
# =============================================================================

# Version control
.git/
.gitignore

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Tests (no se necesitan en la imagen)
app/tests/

# Config & docs
.env
*.md

# Infraestructura (no forma parte de la app)
environment/
terraform/
helm/
pipelines/

# Análisis de código
.sonar/
.scannerwork/
sonar-project.properties
coverage.xml
test-results.xml

# IDE
.vscode/
.idea/
